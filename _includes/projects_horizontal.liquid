<div class="col mb-4">
  <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">
    <div class="card h-100 hoverable">
      <div class="row no-gutters">
        {% if project.img %}
          <div class="col-md-6">
            {% include figure.liquid loading="eager" path=project.img sizes="(min-width: 768px) 156px, 50vw" alt="project thumbnail" class="card-img" %}
          </div>
        {% endif %}
        <div class="{% if project.img %}col-md-6{% else %}col-md-12{% endif %}">
          <div class="card-body">
            <h3 class="card-title">{{ project.title }}</h3>
            <p class="card-text">{{ project.description }}</p>
            {% if project.creator or project.date %}
              <p class="project-card-meta">
                {% if project.creator %}{{ project.creator }}{% endif %}
                {% if project.creator and project.date %}&nbsp;·&nbsp;{% endif %}
                {% if project.date %}{{ project.date | date: '%Y年' }}{% endif %}
              </p>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </a>
</div>
