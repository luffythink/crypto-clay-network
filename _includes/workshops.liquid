<div class="news">
  {% if site.workshops != blank %}
    {% assign workshops_size = site.workshops | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and workshops_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign workshops = site.workshops | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign workshops_limit = page.announcements.limit %}
        {% else %}
          {% assign workshops_limit = workshops_size %}
        {% endif %}
        {% for item in workshops limit: workshops_limit %}
          <tr>
            {% assign display_date = item.event_date | default: item.date %}
            <th scope="row" style="width: 20%">{{ display_date | date: '%Y年%-m月%-d日' }}</th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>暂无工作坊信息。</p>
  {% endif %}
</div>
